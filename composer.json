{
  "name": "amarwave/amarwave-laravel",
  "description": "Official Laravel integration for AmarWave real-time messaging. Service provider, facade, and broadcasting driver.",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "amarwave/amarwave-php": "^1.0",
    "illuminate/broadcasting": "^10.0 || ^11.0 || ^12.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "orchestra/testbench": "^8.0 || ^9.0"
  },
  "autoload": {
    "psr-4": {
      "AmarWave\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AmarWave\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AmarWave\\Laravel\\AmarWaveServiceProvider"
      ],
      "aliases": {
        "AmarWave": "AmarWave\\Laravel\\AmarWaveFacade"
      }
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../php"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true
}
