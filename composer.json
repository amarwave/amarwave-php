{
  "name": "amarwave/amarwave-php",
  "description": "Official php integration for AmarWave real-time messaging. Service provider, facade, and broadcasting driver.",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "amarwave/amarwave-php": "^1.0",
    "illuminate/broadcasting": "^10.0 || ^11.0 || ^12.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "orchestra/testbench": "^8.0 || ^9.0"
  },
  "autoload": {
    "psr-4": {
      "AmarWave\\php\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AmarWave\\php\\Tests\\": "tests/"
    }
  },
  "extra": {
    "php": {
      "providers": [
        "AmarWave\\php\\AmarWaveServiceProvider"
      ],
      "aliases": {
        "AmarWave": "AmarWave\\php\\AmarWaveFacade"
      }
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../php"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true
}
